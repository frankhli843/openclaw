{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Frankclaw feature verification registry. Source of truth for all custom features in the frankclaw fork. Used by verify-frankclaw-features.sh for automated three-probe verification.",
  "version": "1.0.0",
  "features": [
    {
      "name": "Discord DNR quiet hours (replies)",
      "description": "Enforces quiet hours on Discord conversational replies via enforceDiscordDnrWindow",
      "static": [
        {
          "file": "extensions/discord/src/monitor/reply-delivery.ts",
          "pattern": "enforceDiscordDnrWindow",
          "minCount": 1
        }
      ],
      "tests": [],
      "runtime": []
    },
    {
      "name": "Discord DNR quiet hours (outbound)",
      "description": "Enforces quiet hours on Discord outbound messages from cron/sub-agents/raw_send",
      "static": [
        {
          "file": "extensions/discord/src/outbound-adapter.ts",
          "pattern": "enforceDiscordDnrWindow",
          "minCount": 1
        },
        {
          "file": "extensions/discord/src/outbound-adapter.ts",
          "pattern": "checkDiscordOutboundDnr",
          "minCount": 1
        }
      ],
      "tests": [],
      "runtime": []
    },
    {
      "name": "Discord DNR quiet hours (actions)",
      "description": "Enforces quiet hours on Discord action-based sends (sendMessage/threadCreate/threadReply)",
