    {
      "name": "Durable inbound queue",
      "description": "Frankclaw durable worker for Discord inbound message processing with crash recovery",
      "static": [
        {
          "file": "extensions/discord/src/monitor/message-handler.ts",
          "pattern": "durable",
          "minCount": 1
        },
        {
          "file": "extensions/discord/src/monitor/message-handler.ts",
          "pattern": "frankclaw",
          "minCount": 1
        },
        {
          "file": "extensions/discord/src/monitor/inbound-worker.durable.frankclaw.ts",
          "pattern": "frankclaw-durable-worker",
          "minCount": 1
        },
        {
          "file": "extensions/discord/src/monitor/provider.ts",
          "pattern": "client",
          "context": "createDiscordMessageHandler",
          "minCount": 1,
          "note": "client must be passed so durable worker activates"
        }
      ],
      "tests": [
        "extensions/discord/src/monitor/inbound-worker.durable.frankclaw.test.ts",
        "extensions/discord/src/monitor/message-handler.worker.frankclaw.test.ts"
      ],
      "runtime": [
        {
          "logPattern": "[frankclaw-durable-worker] started",
          "withinSeconds": 120
        }
      ]
    },
    {
