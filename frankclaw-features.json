      "tests": [],
      "runtime": []
    },
    {
      "name": "Bed reaction on DNR",
      "description": "Reacts with bed emoji when a message is suppressed by DNR quiet hours",
      "static": [
        {
          "file": "extensions/discord/src/monitor/message-handler.process.ts",
          "pattern": "dnrSuppressed",
          "minCount": 1
        }
      ],
      "tests": [],
      "runtime": []
    },
    {
      "name": "DNR deferred delivery",
      "description": "Enqueues then defers delivery when DNR suppresses a reply (enqueueDelivery before deferDelivery)",
      "static": [
        {
          "file": "extensions/discord/src/monitor/reply-delivery.ts",
          "pattern": "enqueueDelivery",
          "minCount": 1
        }
      ],
      "tests": [],
      "runtime": []
